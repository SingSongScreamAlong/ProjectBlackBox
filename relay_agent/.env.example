# =============================================================================
# BroadcastBox Environment Configuration
# =============================================================================
# Copy this file to .env and customize for your setup

# Server Connection
BLACKBOX_SERVER_URL=http://localhost:3000

# =============================================================================
# STREAMING CONFIGURATION
# =============================================================================

# Master switch for BroadcastBox video streaming (default: disabled)
STREAM_ENABLED=false

# Video quality settings
STREAM_FPS=60                    # Frames per second (30, 60)
STREAM_RESOLUTION=720p           # Resolution (480p, 720p, 1080p)
STREAM_BITRATE=4000              # Bitrate in kbps (2000-8000 typical)
STREAM_CODEC=H264                # Video codec (H264 recommended)

# Transport protocol (WebRTC recommended for lowest latency)
STREAM_TRANSPORT=webrtc          # webrtc, srt, rtmp

# =============================================================================
# NAT TRAVERSAL (STUN/TURN)
# =============================================================================

# STUN servers for NAT traversal (comma-separated)
# Free Google STUN servers work for most setups
STUN_SERVERS=stun:stun.l.google.com:19302,stun:stun1.l.google.com:19302

# TURN server for relaying (required for strict NAT/firewalls)
# Leave empty if not needed - most home setups don't require TURN
TURN_SERVER=
TURN_USERNAME=
TURN_CREDENTIAL=

# =============================================================================
# PERFORMANCE SAFEGUARDS (Zero Driver Impact)
# =============================================================================

# iRacing FPS threshold - stream degrades if FPS drops below this
FAILSAFE_FPS_MIN=55

# System CPU threshold - stream degrades if CPU exceeds this %
FAILSAFE_CPU_MAX=85

# Encoding lag threshold - stream degrades if encoding takes longer than this (ms)
FAILSAFE_ENCODE_LAG_MS=50

# =============================================================================
# ACCESS CONTROL
# =============================================================================

# Who can view your stream
# Options: public, team, league, private
STREAM_ACCESS_LEVEL=public

# =============================================================================
# AUDIO (Phase 2 - Not yet implemented)
# =============================================================================

STREAM_AUDIO_ENABLED=false
STREAM_AUDIO_DEVICE=             # Leave empty for default device

# =============================================================================
# TELEMETRY
# =============================================================================

POLL_RATE_HZ=10
LOG_LEVEL=INFO
LOG_TELEMETRY=false
